# ======================================================================
# Local Dev Server — environment template. Copy to `.env` and fill in.
# NEVER commit a real .env. All secrets are injected via env only.
# ======================================================================

# ---- Core infra (docker-compose service hostnames) -------------------
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/orchestrator?schema=public
REDIS_URL=redis://redis:6379

# Ports exposed on the host
ORCHESTRATOR_PORT=3001
DASHBOARD_PORT=3000

# ---- Dashboard -> Orchestrator wiring --------------------------------
# Public URLs the browser uses to reach the orchestrator (REST + WebSocket).
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:3001
NEXT_PUBLIC_ORCHESTRATOR_WS_URL=ws://localhost:3001

# ======================================================================
# MODEL ROUTING — single source of truth lives in packages/shared.
# The orchestrator injects the right vars into each agent at spawn time
# based on the task tier (routine | complex).
# ======================================================================

# ---- routine tier  ->  local Ollama (Anthropic-compatible endpoint) --
# Ollama runs on the HOST machine. The container reaches it via the docker
# host gateway; on the host directly it's http://localhost:11434.
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Token value is arbitrary for Ollama but must be present.
OLLAMA_AUTH_TOKEN=ollama
# A coding model with tool-use support. Must be pulled into Ollama first.
ROUTINE_MODEL=qwen3-coder:30b

# ---- complex tier  ->  cloud Anthropic API ---------------------------
# Seeds the `claude-cloud` provider with authMode=api-key (pay-per-token).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COMPLEX_MODEL=claude-sonnet-4-6

# Alternative to the above: authMode=oauth-token uses a CLI-minted Claude
# subscription token instead of a pay-per-token API key (run
# `claude setup-token`, or `scripts/cli-auth.sh <provider-name>` to mint +
# register it in one step). Not seeded from env — add/switch a provider to
# it from the dashboard, or via scripts/cli-auth.sh, after first boot; a
# provider on api-key and one on oauth-token can coexist side by side. See
# packages/shared/src/routing.ts resolveProvider() for what this changes
# (bypasses LiteLLM; no subagent delegation from that provider). Using your
# personal subscription this way is your own call against Anthropic's usage
# policies, not something this repo decides for you.

# NOTE: the vars above only SEED two default providers on first boot —
# `ollama-local` (OLLAMA_BASE_URL + ROUTINE_MODEL + OLLAMA_AUTH_TOKEN) and
# `claude-cloud` (ANTHROPIC_API_KEY + COMPLEX_MODEL). After that, manage
# providers (endpoints + models + keys/tokens) in the dashboard → Settings →
# Providers. Agents (./agent/agents/*.md) pick a provider by name.
#
# For a tool-capable local model, pick one that emits structured tool_calls
# (qwen2.5-coder:32b does NOT — it returns tool calls as plain text and breaks
# the agent SDK; qwen3-coder and the Qwopus coder GGUF do). Ollama's native
# /v1/messages works directly, or front it with the compose `litellm` service.

# ---- LiteLLM admin key -----------------------------------------------
# Shared secret between the orchestrator and the litellm proxy, used to manage
# cloud-proxy model routes from the dashboard (LiteLLM admin API). The
# orchestrator is the only caller. Upstream provider keys are NOT set here —
# they live in each provider (DB) and are pushed to litellm per route.
LITELLM_MASTER_KEY=sk-lds-master-dev

# ======================================================================
# AGENT RUNTIME
# ======================================================================
# Path INSIDE the orchestrator container to the git repo agents develop in.
# A per-task worktree + branch is created under here. Leave as-is for docker.
WORKSPACE_REPO_PATH=/workspace/repo

# The workspace is provisioned by the orchestrator into a docker volume by
# default (no host bind needed). Set these to seed it from a git repository;
# leave empty to have agents work in a local git-init'd workspace.
#   REPO_URL=https://github.com/org/project.git
#   REPO_BRANCH=main
#   GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# These seed the DB-backed settings on first boot; thereafter edit them in the
# dashboard Settings page.

# HOST directory the agents work in, bind-mounted to WORKSPACE_REPO_PATH above.
# Visible/seedable on the host; the orchestrator clones repoUrl into it or
# git-inits it. Defaults to ./project.
PROJECT_HOST_PATH=./project

# Root under which per-task git worktrees are created.
WORKTREES_ROOT=/workspace/.worktrees

# Agent operational files (skills + generated per-run settings), kept OUT of the
# project. Container path; host dir is bind-mounted via AGENT_HOST_PATH.
AGENT_DIR=/workspace/agent
AGENT_HOST_PATH=./agent

# Max agentic turns per agent run (safety bound).
AGENT_MAX_TURNS=40

# How many times a task may auto-request "continue?" after hitting the step
# limit before it's stalled instead. Stops a non-converging run (weak model
# grinding, repeating the same failing action) from looping "40 turns →
# continue → 40 turns" forever. Default 2 (i.e. up to 3 runs total).
MAX_CONTINUATIONS=2

# Hard wall-clock ceiling for a single agent run (ms). On expiry the run is
# aborted so it can't wedge a worker slot. Bump it for slow local models.
AGENT_RUN_TIMEOUT_MS=600000

# Strict completion contract. When true, a run that finishes cleanly but never
# called report_task_status is marked `stalled` (not silently `done`) — surfaces
# an agent that talked but did nothing. Leave off if you rely on weak local
# models that can't reliably emit the status tool.
REQUIRE_STATUS_REPORT=true

# ---- Approval gate ---------------------------------------------------
# URL the PreToolUse hook (running inside an agent) uses to reach the
# orchestrator approvals API. Inside docker this is the service name.
APPROVALS_API_URL=http://orchestrator:3001
# How long (seconds) the hook blocks waiting for a human verdict before
# defaulting to DENY (fail-closed).
APPROVAL_TIMEOUT_SECONDS=300

# ======================================================================
# MCP HOST — external-client entry point (Streamable HTTP at /api/mcp)
# ======================================================================
# Lets an external MCP client (Claude Desktop, Claude Code, a browser MCP
# client) create/track tasks on the fleet. Defaults on; set to false to disable.
MCP_HOST_ENABLED=true
# Optional DNS-rebinding guard: a comma-separated Origin allowlist. When set,
# requests whose Origin isn't listed are rejected. Leave empty to accept any
# origin (fine for a localhost-only setup).
# e.g. MCP_ALLOWED_ORIGINS=http://localhost:3000,https://claude.ai
MCP_ALLOWED_ORIGINS=
# Access token. Empty = open (localhost-only posture). STRONGLY recommended once
# the endpoint is exposed publicly (e.g. via an ngrok tunnel for claude.ai): set
# a long random value. Accepted as `Authorization: Bearer <token>` or a `?key=`
# query param (bake it into the connector URL for clients that can't set
# headers, like claude.ai). Generate: `openssl rand -hex 32`.
MCP_TOKEN=

# Skills as a read-on-demand index (name + description + file path) instead of
# inlining every declared skill's full text into the system prompt every turn.
# Big token saving on cheap models; the agent reads a skill file when it needs
# the full conventions. Set false to inline full skill text (old behavior).
SKILLS_LAZY=true

# Auto-deny an identical approval (same tool + signature) once it has already
# been gated this many times on one task — breaks a run that keeps requesting
# the same dangerous action without progress. 0 disables. Default 3.
APPROVAL_REPEAT_LIMIT=3
