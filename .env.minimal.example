# Env overrides for the MINIMAL single-container profile only
# (docker-compose.minimal.yml, install.sh). Copy to `.env.minimal` and fill in.
#
# Do NOT use the root .env.example here — it's written for the multi-service
# `full` profile (real Postgres/Redis service hostnames) and will silently
# break this profile if passed through: DATABASE_URL/REDIS_URL would override
# infra/minimal.Dockerfile's own baked-in SQLite + embedded-queue defaults and
# the container fails to reach a database/Redis that doesn't exist here.
# Only the vars below are meant to be overridden for this profile — anything
# else already has a correct default baked into the image.

# Which tagged release to build (docker-compose.minimal.yml build arg only;
# install.sh gets its version from VERSION/the archive it downloads). Never
# leave this as `latest`/unset for a real deployment — pin an explicit value.
APP_VERSION=0.1.7

# ---- complex tier -> cloud Anthropic API ------------------------------
# Seeds the `claude-cloud` provider with authMode=api-key. To use a Claude
# subscription's CLI-minted token instead (authMode=oauth-token), switch a
# provider to it from the dashboard, or via scripts/cli-auth.sh, after first
# boot — see the fuller note in .env.example.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COMPLEX_MODEL=claude-sonnet-4-6

# ---- routine tier -> local Ollama, reachable from inside the container --
OLLAMA_NATIVE_URL=http://host.docker.internal:11434
ROUTINE_MODEL=qwen3-coder:30b

# Shared secret between the orchestrator and its self-managed LiteLLM child
# process. The image ships a fixed dev default — set your own for anything
# beyond local testing.
LITELLM_MASTER_KEY=sk-lds-master-dev

# MCP host access token — same semantics as the full profile. Empty = open
# (fine for localhost-only). Generate: `openssl rand -hex 32`.
MCP_TOKEN=

# Gates infra/setup-wizard.mjs's "advanced" mode (raw settings tuning beyond
# the guided steps) — a local confirmation speed bump, not a security
# boundary (v1 has no auth anywhere else either). Pick your own — you'll be
# the one typing it back in later (over Telegram, the dashboard, wherever),
# so a random generated string is a poor fit; a short memorable passphrase
# is fine. Empty = advanced mode stays locked.
WIZARD_ADMIN_PASSWORD=
