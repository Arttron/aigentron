// Prisma 7 schema. Mirrors the domain types in @lds/shared.
generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  queued
  running
  needs_approval
  done
  failed
  cancelled
  // agent reported it can't proceed (needs a human); terminal, resumable
  blocked
  // run ended without a status report (timeout/crash); terminal, resumable
  stalled
}

enum AgentSessionStatus {
  starting
  running
  completed
  errored
  cancelled
}

enum ApprovalStatus {
  pending
  approved
  denied
  timeout
}

// Singleton runtime configuration, editable from the dashboard. Seeded from
// environment on first boot; thereafter the DB row is the source of truth and
// the orchestrator reads it at agent-spawn time (no container restart needed).
model AppSettings {
  id String @id @default("singleton")

  approvalTimeoutSeconds Int @default(300)

  // verification gate: shell commands (one per line) run in the worktree after a
  // run; on failure the agent gets up to verifyMaxAttempts auto-fix iterations.
  verifyCommands    String?
  verifyMaxAttempts Int     @default(2)

  // when true the dashboard shows verbose 'assistant' transcript lines
  debugMode Boolean @default(false)

  // instructions appended to every agent's system prompt (the "skill")
  agentInstructions String @default("Before changing anything, inspect the project in your working directory: list the files and read the README and key config files to understand its structure and conventions. Then implement the task with minimal, focused changes that match the existing style.")

  // source repository (optional). When repoUrl is set, the workspace is cloned
  // from it and agent branches push back / open PRs; when empty, agents work in
  // a local git-init'd workspace with no remote.
  repoUrl     String?
  repoBranch  String  @default("main")
  githubToken String?

  // Optional subdirectory within the workspace repo that agents work in (e.g. a
  // package in a monorepo). Empty = the repo root. The write boundary stays the
  // whole worktree; this only sets the agent's working directory (cwd).
  workspaceSubdir String?

  // name of the provider used for tasks that don't pick an agent
  defaultProvider String?

  // named agent used as the lead for tasks that don't pick one (e.g. pm)
  defaultAgent String? @default("pm")

  // Default destination for escalations (an agent's question / a blocked task)
  // from a task with no channel of its own — e.g. one created in the dashboard.
  // channelId = a Channel.id; chatId = the external chat/thread id in it.
  notifyChannelId String?
  notifyChatId    String?

  // roadmap Phase 6 (skill lifecycle): when SkillConsolidationSchedulerService
  // last created a review task for agent/skills/learned/ (null = never run —
  // the first check schedules one immediately if learned/ has content).
  lastSkillConsolidationAt DateTime?
  // How often to schedule a consolidation review. Deliberately NOT the same
  // task run that just wrote a learned skill — self-consolidation inside the
  // evaluated turn that produced the content biases toward self-flattery.
  skillConsolidationIntervalDays Int     @default(7)
  // Agent assigned the consolidation review task; falls back to defaultAgent
  // if this one doesn't exist (checked at schedule time, not here).
  skillConsolidationAgent        String? @default("architect")

  updatedAt DateTime @updatedAt
}

// A person who can act on the system: create tasks, review/approve, or operate.
// Not an auth identity (no credentials in v1) — the acting user is resolved from
// a request header, defaulting to the seeded operator. This is the foundation the
// channel/human-agent work (RFC-001) binds external identities onto.
model User {
  id          String   @id @default(cuid())
  displayName String
  // operator | reviewer | task_setter | admin
  role        String   @default("operator")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  identities   ChannelIdentity[]
  createdTasks Task[]            @relation("TaskCreator")
  resolved     ApprovalRequest[] @relation("ApprovalResolver")
}

// Maps one User to their id on a connected channel (dashboard, Slack, Telegram,
// email). One person, many channels.
model ChannelIdentity {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 'dashboard' | 'slack' | 'telegram' | 'email'
  channel    String
  externalId String
  createdAt  DateTime @default(now())

  @@unique([channel, externalId])
  @@index([userId])
}

// An MCP server agents can use. `config` is the Claude Agent SDK McpServerConfig
// (e.g. { "type": "sse", "url": "..." } or { "command": "...", "args": [...] }).
model McpServer {
  id        String   @id @default(cuid())
  name      String   @unique
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// An AI model endpoint agents can run on. baseUrl null = native Anthropic API.
model Provider {
  id        String   @id @default(cuid())
  name      String   @unique
  // Upstream API family → LiteLLM backend prefix: anthropic | openai | deepseek | ollama.
  kind      String   @default("openai")
  baseUrl   String? // upstream endpoint; null = the family's native default
  model     String // optional default model (may be empty)
  authMode  String   @default("auth-token") // 'api-key' | 'auth-token'
  secret    String? // API key or auth token
  // Optional per-provider rate caps enforced by LiteLLM (for rate-limited
  // upstreams like OpenAI). Null = no cap.
  rpm       Int? // requests per minute
  tpm       Int? // tokens per minute
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id           String     @id @default(cuid())
  prompt       String
  title        String
  status       TaskStatus @default(queued)
  branch       String?
  worktreePath String?
  agentName    String?
  // A real pull request opened for this task's branch (worktree mode).
  prUrl        String?
  // A branch/commit the work was pushed straight to, without a PR (shared mode).
  pushedTo     String?
  error        String?
  // The user who created the task (null for pre-identity / system-created tasks).
  createdById  String?
  createdBy    User?      @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  // Parent task when this is a subtask produced by decomposition (null = top-level).
  parentId     String?
  parent       Task?      @relation("Subtasks", fields: [parentId], references: [id], onDelete: SetNull)
  subtasks     Task[]     @relation("Subtasks")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // External channel that created the task, e.g. "telegram:<chatId>" (null = dashboard).
  createdByChannel String?
  // Provider (model endpoint) to run on, overriding the agent/default — set via
  // a channel's /model command. Null = agent's provider or the default.
  providerOverride String?
  // True while this task has live subtasks it should be resumed for once they
  // all finish (fan-in). Set when it creates a subtask, cleared on wake.
  awaitingSubtasks Boolean @default(false)

  sessions  AgentSession[]
  approvals ApprovalRequest[]
  // Related tasks whose summary is folded into this task's context.
  linksOut  TaskLink[]        @relation("LinkFrom")
  linksIn   TaskLink[]        @relation("LinkTo")
  threads   ChannelThread[]

  @@index([status])
  @@index([createdById])
  @@index([parentId])
}

/// A bidirectional message transport (Telegram bot, later Slack/email). Config
/// holds the bot token + authorized chat ids + a default agent; secrets never
/// reach the browser (masked in the API like Provider/Settings).
model Channel {
  id        String   @id @default(cuid())
  name      String   @unique
  kind      String // 'telegram' (| 'slack' | 'email' later)
  config    Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  threads ChannelThread[]
}

/// Binds a task to a conversation in a channel (one chat/thread ↔ task), so
/// outgoing updates reach the right chat and replies map back to the task.
model ChannelThread {
  id               String   @id @default(cuid())
  channelId        String
  channel          Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  taskId           String
  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  externalThreadId String // Telegram chat id (later: Slack ts / email Message-ID)
  createdAt        DateTime @default(now())

  @@unique([channelId, externalThreadId, taskId])
  @@index([taskId])
  @@index([channelId, externalThreadId])
}

/// Per-conversation session state for a channel: which task the chat is talking
/// to, and the agent/model selected via commands. One row per (channel, chat).
model ChannelChatState {
  id           String   @id @default(cuid())
  channelId    String
  chatId       String
  activeTaskId String?
  agent        String?
  model        String? // provider (model endpoint) name
  // When true, suppress routine task-outcome posts to this chat (approvals still sent).
  muted        Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([channelId, chatId])
}

/// An allowlist rule that auto-approves a matching dangerous tool call, added
/// from the approval dialog. Matches by tool + canonical signature (the classify
/// `summary`: the exact shell command, the written path, or the MCP tool name).
/// scope='global' applies everywhere; scope='task' only to `taskId`.
model ApprovalException {
  id        String   @id @default(cuid())
  scope     String // 'task' | 'global'
  taskId    String? // set when scope='task'
  toolName  String
  signature String
  createdAt DateTime @default(now())

  @@index([toolName])
  @@index([taskId])
}

/// A directed reference from one task to another: `from` pulls `to`'s summary
/// into its working context (so related work is considered during development).
model TaskLink {
  id         String   @id @default(cuid())
  fromTaskId String
  toTaskId   String
  from       Task     @relation("LinkFrom", fields: [fromTaskId], references: [id], onDelete: Cascade)
  to         Task     @relation("LinkTo", fields: [toTaskId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([fromTaskId, toTaskId])
  @@index([toTaskId])
}

model AgentSession {
  id              String             @id @default(cuid())
  taskId          String
  task            Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  status          AgentSessionStatus @default(starting)
  provider        String // provider name the run used
  model           String
  // Claude Code session id captured from the SDK init event (for --resume).
  claudeSessionId String?
  // Structured outcome the agent declared via report_task_status (done|failed|blocked).
  reportedStatus  String?
  reportedSummary String?
  // Last time the agent called heartbeat() (liveness for long runs).
  lastHeartbeatAt DateTime?
  startedAt       DateTime           @default(now())
  endedAt         DateTime?

  // Usage from the SDK result stream, accumulated across the run AND its
  // reporting-resume, for per-provider stats (roadmap Phase 5). Nullable:
  // populated from the Phase-1 deploy onward; pre-existing rows stay null.
  inputTokens         Int?
  outputTokens        Int?
  cacheReadTokens     Int?
  cacheCreationTokens Int?
  numTurns            Int?
  costUsd             Float?
  apiMs               Int?

  events    AgentEvent[]
  approvals ApprovalRequest[]

  @@index([taskId])
}

// A single streamed line of agent output — the persisted transcript.
model AgentEvent {
  id             String       @id @default(cuid())
  agentSessionId String
  session        AgentSession @relation(fields: [agentSessionId], references: [id], onDelete: Cascade)
  taskId         String
  seq            Int
  kind           String
  text           String
  // Attachment filenames for `prompt` (user message) events — inline thumbnails.
  attachments    String[]     @default([])
  createdAt      DateTime     @default(now())

  @@index([agentSessionId, seq])
  @@index([taskId])
}

model ApprovalRequest {
  id             String         @id @default(cuid())
  taskId         String
  task           Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agentSessionId String?
  session        AgentSession?  @relation(fields: [agentSessionId], references: [id], onDelete: SetNull)
  toolName       String
  toolInput      Json
  summary        String
  reason         String
  status         ApprovalStatus @default(pending)
  // Human-readable label of who/what resolved it (e.g. a display name, or
  // 'system:timeout'). Kept for system markers that have no User.
  resolvedBy     String?
  // The user who resolved it, when a human did (null for system:timeout).
  resolvedById   String?
  resolver       User?          @relation("ApprovalResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  resolvedAt     DateTime?

  @@index([status])
  @@index([taskId])
  @@index([resolvedById])
}

/// A pending job for the EMBEDDED queue driver (minimal profile; REDIS_URL
/// unset). BullMQ installs use Redis and never touch this table. Claimed rows
/// belong to a live in-process worker; stale claims from a crashed process are
/// deleted on worker start (one-attempt semantics — the task itself is
/// reconciled to `stalled` by the orphan sweep).
model QueueJob {
  id        String    @id @default(cuid())
  taskId    String
  /// JSON-encoded TaskJobData (followUpPrompt, attachments).
  payload   String
  /// Set to the taskId for initial runs (deduped per task); null for follow-ups.
  dedupKey  String?
  runAfter  DateTime  @default(now())
  claimedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([runAfter, claimedAt])
  @@index([taskId])
}

/// A LiteLLM route for the MANAGED litellm driver (minimal profile;
/// LITELLM_MANAGED=1 — docs/plan-single-container.md Phase 3). The `full`
/// profile's admin-API driver never touches this table — routes there live in
/// litellm's OWN Postgres (STORE_MODEL_IN_DB). Managed mode has no such DB, so
/// this table is the equivalent persisted registry: LitellmManagedService
/// renders it (+ a static base) into litellm-config.yaml and restarts the
/// child litellm process whenever a row changes.
model ManagedLitellmRoute {
  id        String   @id @default(cuid())
  /// The model_name litellm serves, e.g. `ollama-local/qwen3-coder:30b`.
  name      String   @unique
  /// Backend, e.g. `ollama_chat/qwen3-coder:30b` (prefix already applied).
  backend   String
  apiBase   String?
  apiKey    String?
  rpm       Int?
  tpm       Int?
  /// True when the upstream is a non-reasoning model — drop extended-thinking
  /// params litellm would otherwise forward (mirrors litellm.service.ts NO_REASONING).
  dropReasoning Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
