{
  "name": "@lds/orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS orchestrator: task lifecycle, agent supervision, model routing, approvals.",
  "main": "dist/main.js",
  "scripts": {
    "build": "pnpm prisma:generate:all && nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:generate:sqlite": "prisma generate --schema=prisma/sqlite/schema.prisma",
    "prisma:generate:all": "pnpm prisma:generate && pnpm prisma:generate:sqlite",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:deploy:sqlite": "prisma migrate deploy --config prisma.sqlite.config.ts",
    "prisma:sync": "node prisma/generate-sqlite-schema.mjs"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@lds/agent-runner": "workspace:*",
    "@lds/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/platform-socket.io": "^11.1.0",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/websockets": "^11.1.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.79.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "dotenv": "^17.0.0",
    "prisma": "^7.8.0"
  }
}
